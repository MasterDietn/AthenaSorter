  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #2a6048fa)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #141e18fa))
