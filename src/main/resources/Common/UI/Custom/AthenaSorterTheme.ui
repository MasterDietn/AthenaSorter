// AthenaSorter — AthenaQuest visual style (textures in Textures/AthenaSorter/)

@WindowBg = #141c18ff;
@PanelBg = #121a18ff;
@AccentGold = #d4a345;
@AccentGreen = #8ee4b8;
@AccentGreenBright = #6ee7b7;

@TitleStyle = (FontSize: 17, TextColor: #eef6f0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, LetterSpacing: 2);
@SubtitleStyle = (FontSize: 12, TextColor: #c8e0d4, HorizontalAlignment: Center, VerticalAlignment: Center);
@NavTitleStyle = (FontSize: 14, TextColor: #eef6f0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, LetterSpacing: 1);
@SectionStyle = (FontSize: 11, TextColor: #d4a345, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Start);
@BadgeStyle = (FontSize: 15, TextColor: #8ee4b8, RenderBold: true, HorizontalAlignment: Center);
@HintStyle = (FontSize: 13, TextColor: #6ee7b7, RenderBold: true, HorizontalAlignment: Center);
@BodyStyle = (FontSize: 14, TextColor: #ecf8f0, HorizontalAlignment: Center);
@MutedStyle = (FontSize: 13, TextColor: #5a9880, HorizontalAlignment: Center);

@StorylineStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #7a5a18f0)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #a87828f0)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #5a4010f0))
);

@TabStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #141c18cc)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #1e2e28e8)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #101810f0))
);

@TabActiveStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #2d6a48e8)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #35885ae8)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #245a3ae8))
);

@PrimaryStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #1e5238f0)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #2a6848f0)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #183828f0))
);

@SuccessStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #2d6a48f0)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #35885af0)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #245a3af0))
);

@DangerStyle = ButtonStyle(
  Default: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #5a2020e0)),
  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #7a3030e0)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #401010e0))
