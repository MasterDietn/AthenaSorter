  Hovered: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #2a4038fa)),
  Pressed: (Background: (TexturePath: "Textures/AthenaSorter/RoundedChip.png", Border: 12, Color: #0e1412fa))
