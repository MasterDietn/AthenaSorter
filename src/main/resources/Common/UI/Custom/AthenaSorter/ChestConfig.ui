// AthenaSorter — Kisten-Konfiguration (groß, feste Button-Positionen)

Group {
  Anchor: (Full: 0);
  LayoutMode: Center;
  Background: (Color: #000000(0.65));

  Group #WindowBorder {
    Anchor: (Width: 680, Height: 760);
    Background: (Color: #4a5568);
    Padding: (Full: 3);

    Group #WindowPanel {
      Anchor: (Full: 0);
      Background: (Color: #1a2028);
      Padding: (Full: 22);

      Label #Title {
        Text: "AthenaSorter";
        Anchor: (Top: 0, Left: 0, Right: 0, Height: 34);
        Style: (FontSize: 28, TextColor: #f7fafc, RenderBold: true, HorizontalAlignment: Center);
      }

      Label #Subtitle {
        Text: "Automatisches Lagern";
        Anchor: (Top: 38, Left: 0, Right: 0, Height: 22);
        Style: (FontSize: 15, TextColor: #a0aec0, HorizontalAlignment: Center);
      }

      Group #HelpBox {
        Anchor: (Top: 68, Left: 0, Right: 0, Height: 88);
        Background: (Color: #2d3748);
        Padding: (Full: 12);
        Label #HelpLine1 {
          Text: "1. Eine Kiste als Eingang festlegen";
          Anchor: (Top: 0, Left: 0, Right: 0, Height: 22);
          Style: (FontSize: 14, TextColor: #cbd5e0, HorizontalAlignment: Center);
        }
        Label #HelpLine2 {
          Text: "2. Weitere Kisten als Speicher + Item-Typen";
          Anchor: (Top: 24, Left: 0, Right: 0, Height: 22);
          Style: (FontSize: 14, TextColor: #cbd5e0, HorizontalAlignment: Center);
        }
        Label #HelpLine3 {
          Text: "3. Items in die Eingangskiste legen";
          Anchor: (Top: 48, Left: 0, Right: 0, Height: 22);
          Style: (FontSize: 14, TextColor: #cbd5e0, HorizontalAlignment: Center);
        }
      }

      Label #RoleBadge {
        Text: "Status: Nicht eingerichtet";
        Anchor: (Top: 162, Left: 0, Right: 0, Height: 28);
        Style: (FontSize: 17, TextColor: #63b3ed, RenderBold: true, HorizontalAlignment: Center);
      }

      Group #RoleButtons {
        Anchor: (Top: 198, Height: 52, Left: 0, Right: 0);

        Button #SetInputBtn {
          Anchor: (Width: 190, Height: 44, Top: 4, Left: 32);
          Style: (Default: (Background: (Color: #2b6cb0)), Hovered: (Background: (Color: #3182ce)));
          Label { Text: "Eingangskiste"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 15, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #SetStorageBtn {
          Anchor: (Width: 190, Height: 44, Top: 4, Left: 242);
          Style: (Default: (Background: (Color: #276749)), Hovered: (Background: (Color: #2f855a)));
          Label { Text: "Speicherkiste"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 15, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #ClearRoleBtn {
          Anchor: (Width: 140, Height: 44, Top: 4, Left: 458);
          Style: (Default: (Background: (Color: #742a2a)), Hovered: (Background: (Color: #9b2c2c)));
          Label { Text: "Entfernen"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
      }

      Label #FilterHint {
        Text: "Speicherkiste: Item in Hand + Slot klicken";
        Anchor: (Top: 262, Left: 0, Right: 0, Height: 22);
        Style: (FontSize: 14, TextColor: #68d391, HorizontalAlignment: Center);
      }

      Group #FilterGrid {
        Anchor: (Top: 290, Left: 0, Right: 0, Height: 180);
        LayoutMode: Center;
        Group #FilterContainer {
          Anchor: (Width: 230, Height: 174);
          Button #FilterBtn0 { Anchor: (Width: 52, Height: 52, Top: 0, Left: 0); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon0 { Anchor: (Full: 0); } }
          Button #FilterBtn1 { Anchor: (Width: 52, Height: 52, Top: 0, Left: 58); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon1 { Anchor: (Full: 0); } }
          Button #FilterBtn2 { Anchor: (Width: 52, Height: 52, Top: 0, Left: 116); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon2 { Anchor: (Full: 0); } }
          Button #FilterBtn3 { Anchor: (Width: 52, Height: 52, Top: 0, Left: 174); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon3 { Anchor: (Full: 0); } }
          Button #FilterBtn4 { Anchor: (Width: 52, Height: 52, Top: 58, Left: 0); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon4 { Anchor: (Full: 0); } }
          Button #FilterBtn5 { Anchor: (Width: 52, Height: 52, Top: 58, Left: 58); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon5 { Anchor: (Full: 0); } }
          Button #FilterBtn6 { Anchor: (Width: 52, Height: 52, Top: 58, Left: 116); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon6 { Anchor: (Full: 0); } }
          Button #FilterBtn7 { Anchor: (Width: 52, Height: 52, Top: 58, Left: 174); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon7 { Anchor: (Full: 0); } }
          Button #FilterBtn8 { Anchor: (Width: 52, Height: 52, Top: 116, Left: 0); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon8 { Anchor: (Full: 0); } }
          Button #FilterBtn9 { Anchor: (Width: 52, Height: 52, Top: 116, Left: 58); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon9 { Anchor: (Full: 0); } }
          Button #FilterBtn10 { Anchor: (Width: 52, Height: 52, Top: 116, Left: 116); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon10 { Anchor: (Full: 0); } }
          Button #FilterBtn11 { Anchor: (Width: 52, Height: 52, Top: 116, Left: 174); Padding: (Full: 2); Style: (Default: (Background: (Color: #000000(0.45))), Hovered: (Background: (Color: #ffffff(0.15)))); ItemIcon #FilterIcon11 { Anchor: (Full: 0); } }
        }
      }

      Group #PageControls {
        Anchor: (Top: 472, Height: 36, Left: 0, Right: 0);
        Button #PrevPage {
          Anchor: (Width: 40, Height: 32, Top: 2, Left: 260);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: "<"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #e2e8f0, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Label #PageLabel {
          Text: "Seite 1/1";
          Anchor: (Width: 100, Height: 32, Top: 2, Left: 310);
          Style: (FontSize: 15, TextColor: #a0aec0, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
        Button #NextPage {
          Anchor: (Width: 40, Height: 32, Top: 2, Left: 400);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: ">"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #e2e8f0, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
      }

      Label #RadiusLabel {
        Text: "Suchradius: 32 Blöcke";
        Anchor: (Top: 512, Left: 0, Right: 0, Height: 24);
        Style: (FontSize: 15, TextColor: #e2e8f0, HorizontalAlignment: Center);
      }
      Group #RadiusControls {
        Anchor: (Top: 540, Height: 36, Left: 0, Right: 0);
        Button #RadiusDec {
          Anchor: (Width: 44, Height: 32, Top: 2, Left: 260);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: "-"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #RadiusInc {
          Anchor: (Width: 44, Height: 32, Top: 2, Left: 360);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: "+"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
      }

      Label #IntervalLabel {
        Text: "Geschwindigkeit: 1.0s";
        Anchor: (Top: 576, Left: 0, Right: 0, Height: 24);
        Style: (FontSize: 15, TextColor: #e2e8f0, HorizontalAlignment: Center);
      }
      Group #IntervalControls {
        Anchor: (Top: 604, Height: 36, Left: 0, Right: 0);
        Button #IntervalDec {
          Anchor: (Width: 44, Height: 32, Top: 2, Left: 260);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: "-"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #IntervalInc {
          Anchor: (Width: 44, Height: 32, Top: 2, Left: 360);
          Style: (Default: (Background: (Color: #2d3748)), Hovered: (Background: (Color: #4a5568)));
          Label { Text: "+"; Anchor: (Full: 0); Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
      }

      Group #Footer {
        Anchor: (Bottom: 10, Left: 0, Right: 0, Height: 44);

        Button #ClearFiltersBtn {
          Anchor: (Width: 150, Height: 38, Top: 4, Left: 30);
          Style: (Default: (Background: (Color: #744210)), Hovered: (Background: (Color: #975a16)));
          Label { Text: "Filter leeren"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #CloseButton {
          Anchor: (Width: 150, Height: 38, Top: 4, Left: 250);
          Style: (Default: (Background: (Color: #4a5568)), Hovered: (Background: (Color: #718096)));
          Label { Text: "Schliessen"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 15, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
        Button #OpenMenuBtn {
          Anchor: (Width: 150, Height: 38, Top: 4, Left: 470);
          Style: (Default: (Background: (Color: #2b6cb0)), Hovered: (Background: (Color: #3182ce)));
          Label { Text: "Hauptmenü"; Anchor: (Full: 0); Style: (TextColor: #ffffff, FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center); }
        }
      }
    }
  }
}
